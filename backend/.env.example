# Data Terminal 后端环境变量示例
# 复制本文件为 .env 并按需修改

# 应用
APP_NAME=Data Terminal
DEBUG=true

# 数据库
DATABASE_URL=sqlite:///./data/data_terminal.db

# API
API_V1_PREFIX=/api/v1

# 定时任务调度器（false 可禁用每日自动更新）
SCHEDULER_ENABLED=true

# 代理配置（如遇到 yfinance 网络限制可开启）
# 支持格式: socks5://127.0.0.1:1082 或 http://127.0.0.1:1089
# 如不想使用代理，直接注释掉或留空即可
# PROXY_URL=socks5://127.0.0.1:1082
